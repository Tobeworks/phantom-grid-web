# Phantom Grid Web — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# ── PocketBase ────────────────────────────────────────────────────────────────
# Local dev: run ./pocketbase serve and set to http://localhost:8090
# Production: internal k8s service (set via deployment.yaml env)
POCKETBASE_URL=http://localhost:8090

# ── SMTP (Nodemailer / Newsletter) ───────────────────────────────────────────
# Local dev: use Mailpit (brew install mailpit) → SMTP on port 1025
# Production: set to your real SMTP provider
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=newsletter@phantom-grid.de
SMTP_PASS=
SMTP_FROM=newsletter@phantom-grid.de
