---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import LedArray from '../components/LedArray.astro';
---

<BaseLayout title="PHANTOM GRID — Design System">
  <div class="design-sys">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <header class="design-sys__header mb-16 pb-8">
      <span class="design-sys__eyebrow text-eyebrow block mb-2">PHANTOM GRID</span>
      <h1 class="design-sys__title text-display mb-2" style="font-size:3rem; letter-spacing:0.2em;">Design System</h1>
      <p class="design-sys__subtitle text-dim">Visual language reference — all components, tokens, and effects.</p>
    </header>

    <!-- ── Colors ─────────────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">Colors</h2>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Accent</h3>
        <div class="flex flex-wrap gap-4">
          <div class="swatch">
            <div class="swatch__preview" style="background:#D6524C;"></div>
            <code class="swatch__token">--color-accent</code>
            <span class="swatch__hex">#D6524C</span>
            <span class="swatch__name">Dirty Red</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:#7A1A17;"></div>
            <code class="swatch__token">--color-accent-deep</code>
            <span class="swatch__hex">#7A1A17</span>
            <span class="swatch__name">Deep Red</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:rgba(214,82,76,0.5);"></div>
            <code class="swatch__token">--color-accent-glow</code>
            <span class="swatch__hex">rgba(214,82,76,0.5)</span>
            <span class="swatch__name">Glow</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:rgba(214,82,76,0.18);"></div>
            <code class="swatch__token">--color-accent-dim</code>
            <span class="swatch__hex">rgba(214,82,76,0.18)</span>
            <span class="swatch__name">Dim</span>
          </div>
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Surfaces</h3>
        <div class="flex flex-wrap gap-4">
          <div class="swatch">
            <div class="swatch__preview" style="background:#0E0E0E; border:1px solid #333;"></div>
            <code class="swatch__token">--color-bg</code>
            <span class="swatch__hex">#0E0E0E</span>
            <span class="swatch__name">Background</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:#141414; border:1px solid #333;"></div>
            <code class="swatch__token">--color-surface-low</code>
            <span class="swatch__hex">#141414</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:#1A1A1A; border:1px solid #333;"></div>
            <code class="swatch__token">--color-surface</code>
            <span class="swatch__hex">#1A1A1A</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:#222222; border:1px solid #333;"></div>
            <code class="swatch__token">--color-surface-high</code>
            <span class="swatch__hex">#222222</span>
          </div>
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Foreground</h3>
        <div class="flex flex-wrap gap-4">
          <div class="swatch">
            <div class="swatch__preview" style="background:#DCDCDC;"></div>
            <code class="swatch__token">--color-fg</code>
            <span class="swatch__hex">#DCDCDC</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:rgba(220,220,220,0.4);"></div>
            <code class="swatch__token">--color-fg-dim</code>
            <span class="swatch__hex">rgba(220,220,220,0.4)</span>
          </div>
          <div class="swatch">
            <div class="swatch__preview" style="background:rgba(220,220,220,0.2);"></div>
            <code class="swatch__token">--color-fg-muted</code>
            <span class="swatch__hex">rgba(220,220,220,0.2)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Typography ─────────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">Typography</h2>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Barlow Condensed — Label Font</h3>
        <div class="flex flex-col gap-6">
          <div class="type-sample">
            <span class="text-micro mb-1 block">Hero / 700 / clamp(2.5–5rem) / tracking 0.25em — <code>.text-hero</code></span>
            <span class="text-hero">PHANTOM GRID</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Display / 700 / 2.5rem / tracking 0.25em — <code>.text-display</code></span>
            <span class="text-display">VECTOR FIELD SIGNALS</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Headline / 700 / 1.5rem / tracking 0.2em — <code>.text-headline</code></span>
            <span class="text-headline">INPUT NULL — EP</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Label / 600 / 0.875rem / tracking 0.15em — <code>.text-label</code></span>
            <span class="text-label">CATALOG · PG-001</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Eyebrow / 600 / 0.65rem / tracking 0.4em — <code>.text-eyebrow</code></span>
            <span class="text-eyebrow">EST. 2026 — CYBERSPACE</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Micro / 600 / 0.65rem / tracking 0.2em — <code>.text-micro</code></span>
            <span class="text-micro">metadata · runtime · bpm · key</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Dim / 0.875rem / tracking 0.1em — <code>.text-dim</code></span>
            <span class="text-dim">Secondary body copy and descriptions.</span>
          </div>
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Phosphor Glow — Effects</h3>
        <div class="flex flex-col gap-6">
          <div class="type-sample">
            <span class="text-micro mb-1 block">VHS Chromatic Aberration — <code>.glow-fg</code></span>
            <span class="text-hero glow-fg">PHANTOM GRID</span>
          </div>
          <div class="type-sample">
            <span class="text-micro mb-1 block">Neon Bloom Accent — <code>.glow-accent</code></span>
            <span class="text-headline glow-accent" style="color: var(--color-accent);">SIGNAL INCOMING</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Visual Effects ─────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">Visual Effects</h2>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4">
        <div class="effect-card pg-surface-low flex flex-col gap-4 p-6">
          <span class="effect-card__label">Neon Bloom — Accent</span>
          <div class="effect-card__demo glow-accent" style="color: var(--color-accent);">SIGNAL</div>
          <code class="effect-card__code">text-shadow: 0 0 10px rgba(214,82,76,0.5)</code>
        </div>

        <div class="effect-card pg-surface-low flex flex-col gap-4 p-6">
          <span class="effect-card__label">Phosphor Glow — Foreground</span>
          <div class="effect-card__demo glow-fg">TRANSMISSION</div>
          <code class="effect-card__code">Chromatic aberration + bloom</code>
        </div>

        <div class="effect-card pg-surface-low flex flex-col gap-4 p-6">
          <span class="effect-card__label">Box Glow — Surface</span>
          <div class="effect-card__demo">
            <div style="padding:0.5rem 1rem; border:1px solid rgba(214,82,76,0.3); box-shadow: 0 0 15px rgba(214,82,76,0.2), inset 0 0 10px rgba(214,82,76,0.05);">PG-001</div>
          </div>
          <code class="effect-card__code">box-shadow: 0 0 15px rgba(214,82,76,0.2)</code>
        </div>

        <div class="effect-card pg-surface-low flex flex-col gap-4 p-6">
          <span class="effect-card__label">Cursor Blink</span>
          <div class="effect-card__demo">READY <span class="pg-cursor"></span></div>
          <code class="effect-card__code">.pg-cursor — step-end infinite, 1.2s</code>
        </div>
      </div>
    </section>

    <!-- ── LED Array ──────────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">LED Array</h2>
      <p class="design-sys__subtitle text-dim mb-8">
        Each character of the catalog code is ASCII-encoded as one row of 8 bits.
        The dot matrix is the binary representation of the release — notation, not decoration.
        Active LEDs flicker via JS interval.
      </p>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Props</h3>
        <table class="led-docs__table">
          <thead>
            <tr>
              <th>Prop</th>
              <th>Type</th>
              <th>Default</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>code</code></td>
              <td><code>string</code></td>
              <td><code>"PG-001"</code></td>
              <td>Catalog number — each character encodes as one row of 8 LEDs (ASCII binary)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Encoding — PG-001</h3>
        <div class="led-docs__encoding mb-8">
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">P</span>
            <span class="led-docs__bits">01010000</span>
            <span class="text-micro">ASCII 80</span>
          </div>
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">G</span>
            <span class="led-docs__bits">01000111</span>
            <span class="text-micro">ASCII 71</span>
          </div>
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">-</span>
            <span class="led-docs__bits">00101101</span>
            <span class="text-micro">ASCII 45</span>
          </div>
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">0</span>
            <span class="led-docs__bits">00110000</span>
            <span class="text-micro">ASCII 48</span>
          </div>
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">0</span>
            <span class="led-docs__bits">00110000</span>
            <span class="text-micro">ASCII 48</span>
          </div>
          <div class="led-docs__encoding-row">
            <span class="led-docs__char">1</span>
            <span class="led-docs__bits">00110001</span>
            <span class="text-micro">ASCII 49</span>
          </div>
        </div>
        <div class="design-sys__led-wrapper">
          <LedArray code="PG-001" />
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Example — PG-002</h3>
        <p class="design-sys__subtitle text-dim mb-6">Next release — different dot pattern, same encoding logic.</p>
        <div class="design-sys__led-wrapper">
          <LedArray code="PG-002" />
        </div>
      </div>

      <div class="design-sys__group">
        <h3 class="design-sys__group-title pg-group-title">Usage</h3>
        <div class="pg-code-block">
          <code>&lt;LedArray code="PG-001" /&gt;</code>
          <code>&lt;LedArray code="PG-002" /&gt;</code>
          <code>&lt;LedArray /&gt;  {/* defaults to PG-001 */}</code>
        </div>
      </div>
    </section>

    <!-- ── Terminal ───────────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">Terminal</h2>
      <Terminal
        title="PHANTOM_GRID_OS"
        lines={[
          'git submodule update --remote',
          '> Submodule path: phantom-grid-os',
          '> HEAD is now at 42abae4',
          'pnpm build',
          '> ✓ 2 page(s) built in 940ms',
          'git commit -m "feat: PG-001 release"',
          '> [main a91dc6b] feat: PG-001 release',
        ]}
      />
    </section>

    <!-- ── Components ─────────────────────────────────────────────── -->
    <section class="design-sys__section mb-16">
      <h2 class="design-sys__section-title pg-section-title">Components</h2>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Buttons</h3>
        <div class="flex flex-wrap gap-4 items-center">
          <button class="btn btn--primary">RELEASE NOW</button>
          <button class="btn btn--ghost">VIEW CATALOG</button>
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Badges</h3>
        <div class="flex flex-wrap gap-4 items-center">
          <span class="badge">PG-001</span>
          <span class="badge">EP</span>
          <span class="badge">IN PRODUCTION</span>
          <span class="badge badge--muted">PENDING</span>
        </div>
      </div>

      <div class="design-sys__group mb-10">
        <h3 class="design-sys__group-title pg-group-title">Input</h3>
        <input class="pg-input" placeholder="SEARCH CATALOG_" />
      </div>

      <div class="design-sys__group">
        <h3 class="design-sys__group-title pg-group-title">Divider</h3>
        <div class="pg-divider"></div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Page wrapper ── */
  .design-sys {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
    height: 100vh;
    overflow-y: auto;
  }

  .design-sys__header {
    border-bottom: 1px solid var(--color-border);
  }

  .design-sys__led-wrapper {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  /* ── Swatch block ── */
  .swatch {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 140px;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--color-fg-dim);
  }

  .swatch__preview {
    height: 3.5rem;
    border-radius: 2px;
    margin-bottom: 0.25rem;
  }

  .swatch__token {
    color: var(--color-fg);
    font-size: 0.6rem;
  }

  .swatch__hex  { font-size: 0.6rem; }

  .swatch__name {
    color: var(--color-accent);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
  }

  /* ── Type sample block ── */
  .type-sample {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .type-sample:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* ── Effect card block ── */
  .effect-card__label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
  }

  .effect-card__demo {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-fg);
    min-height: 3rem;
    display: flex;
    align-items: center;
  }

  .effect-card__code {
    font-size: 0.6rem;
    color: var(--color-fg-muted);
    letter-spacing: 0.05em;
    font-family: monospace;
  }

  /* ── LED Array docs ── */
  .led-docs__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .led-docs__table th {
    text-align: left;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
    padding: 0.5rem 1rem 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .led-docs__table td {
    padding: 0.6rem 1rem 0.6rem 0;
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .led-docs__table td:last-child { color: var(--color-fg-dim); }

  .led-docs__table code {
    color: var(--color-accent);
    font-size: 0.7rem;
  }

  .led-docs__encoding {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
  }

  .led-docs__encoding-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .led-docs__char {
    color: var(--color-accent);
    font-weight: 700;
    width: 1rem;
    text-align: center;
    text-shadow: 0 0 8px rgba(214, 82, 76, 0.5);
  }

  .led-docs__bits {
    color: var(--color-fg);
    letter-spacing: 0.3em;
  }

  /* ── Code block (reuse candidate once 3rd use appears) ── */
  .pg-code-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-surface-low);
    border: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
  }

  .pg-code-block code { color: var(--color-fg-dim); }
</style>
