---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { getPromoByToken, getFeedbackForRelease } from '../../lib/pocketbase';
import { promoErrorPage } from '../../lib/errorPages';
import releasesData from '../../../phantom-grid-os/data/releases.json';

const { slug } = Astro.params;
const token = Astro.url.searchParams.get('t');

// Guard: missing token
if (!token) return Astro.redirect('/404');

// Validate promo
const promo = await getPromoByToken(token);

// Guard: invalid token or wrong release
if (!promo || promo.release_slug !== slug) {
  return new Response(
    promoErrorPage(404, 'INVALID PROMO LINK', 'THIS TOKEN DOES NOT EXIST OR HAS BEEN REVOKED.'),
    { status: 404, headers: { 'content-type': 'text/html' } }
  );
}

// Guard: expired
const isExpired = promo.expires_at ? new Date(promo.expires_at) < new Date() : false;
if (isExpired) {
  return new Response(
    promoErrorPage(410, 'PROMO LINK EXPIRED', 'CONTACT PHANTOM GRID FOR AN UPDATED LINK.'),
    { status: 410, headers: { 'content-type': 'text/html' } }
  );
}

// Resolve release
const release = releasesData.releases.find(
  (r) => r.catalog.toLowerCase() === slug
);
if (!release) return Astro.redirect('/404');

const { catalog, artist, title, format, year, genre, artwork, cover, tracks } = release;

const playerTracks = tracks.map((t) => ({
  number: t.number,
  title:  t.title,
  url:    t.url,
}));

const artWebp = artwork?.['600']?.webp || cover;
const artJpg  = artwork?.['600']?.jpg  || cover;

const feedbacks = await getFeedbackForRelease(slug!);
---

<BaseLayout
  title={`${artist} — ${title} // PROMO`}
  description="Restricted promo listening page — Phantom Grid."
>
  <div class="max-w-7xl mx-auto px-8 py-8 pb-24 min-h-screen">
    <div class="promo__box">

      <!-- Box header -->
      <div class="promo__box-header flex items-center justify-between px-6 py-3 border-b border-border">
        <span class="text-eyebrow text-accent tracking-[0.35em]">RESTRICTED // PROMO USE ONLY</span>
        <span class="text-micro text-fg-muted">PHANTOM GRID</span>
      </div>

      <div class="px-6 py-8 flex flex-col gap-8">

    <!-- Release header -->
    <div class="promo__section flex gap-8 items-start">
      {artJpg && (
        <picture class="flex-shrink-0">
          <source srcset={artWebp} type="image/webp" />
          <img
            src={artJpg}
            alt={`${artist} — ${title}`}
            width="160"
            height="160"
            class="promo__cover block border border-border w-40 h-40 object-cover"
          />
        </picture>
      )}
      <div class="flex flex-col gap-2 pt-1">
        <div class="flex gap-2 flex-wrap">
          <span class="badge">{catalog}</span>
          {format && <span class="badge badge--muted">{format}</span>}
          {genre  && <span class="badge badge--muted">{genre}</span>}
          {year   && <span class="badge badge--muted">{year}</span>}
        </div>
        <h1 class="font-label font-bold uppercase text-fg text-[1.6rem] tracking-[0.15em] leading-tight mt-1">{title}</h1>
        <p class="text-micro">{artist}</p>
        <p class="text-micro text-accent tracking-[0.3em]">FOR: {promo.recipient_name.toUpperCase()}</p>
        {promo.expires_at && (
          <p class="text-micro text-fg-muted tracking-[0.2em]">
            VALID UNTIL: {new Date(promo.expires_at).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })}
          </p>
        )}
      </div>
    </div>

    <!-- Audio player -->
    <div class="promo__section">
      <AudioPlayer tracks={playerTracks} />
    </div>

    <!-- Downloads -->
    <div class="promo__section">
      <p class="pg-section-title">// DOWNLOAD</p>

      <!-- ZIP all tracks -->
      <div class="flex gap-3 mb-6">
        <a
          href={`/api/promo/download?t=${token}&q=128`}
          class="btn btn--ghost"
          data-dl
          download
        >
          ↓ ALL TRACKS · 128K
        </a>
        <a
          href={`/api/promo/download?t=${token}&q=320`}
          class="btn btn--primary"
          data-dl
          download
        >
          ↓ ALL TRACKS · 320K
        </a>
      </div>

      <ol class="promo__tracklist">
        {tracks.map((track) => {
          const label = track.title.replace(/^.*?\s{2,}/, '').trim() || track.title;
          return (
            <li class="promo__track-row">
              <span class="text-micro text-fg-muted w-6 flex-shrink-0">
                {String(track.number).padStart(2, '0')}
              </span>
              <span class="font-label font-semibold uppercase text-fg-dim text-[0.78rem] tracking-[0.1em] flex-1 truncate">
                {label}
              </span>
              <div class="flex gap-2 flex-shrink-0">
                <a
                  href={`/api/promo/download?t=${token}&q=128&track=${track.number}`}
                  class="btn btn--ghost text-[0.6rem] py-1 px-3"
                  data-dl
                  download
                >
                  128K
                </a>
                <a
                  href={`/api/promo/download?t=${token}&q=320&track=${track.number}`}
                  class="btn btn--primary text-[0.6rem] py-1 px-3"
                  data-dl
                  download
                >
                  320K
                </a>
              </div>
            </li>
          );
        })}
      </ol>
    </div>

    <!-- Feedback form -->
    <div class="promo__section" id="promo-feedback-wrap">
      <p class="pg-section-title">// FEEDBACK</p>

      <form id="promo-feedback-form" class="flex flex-col gap-5">
        <input type="hidden" name="token" value={token} />

        <div class="flex flex-col gap-2">
          <label class="text-eyebrow" for="fb-name">NAME</label>
          <input
            id="fb-name"
            name="name"
            type="text"
            class="pg-input"
            placeholder="YOUR NAME"
            required
          />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-eyebrow" for="fb-email">EMAIL</label>
          <input
            id="fb-email"
            name="email"
            type="email"
            class="pg-input"
            placeholder="YOUR@EMAIL.COM"
            required
          />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-eyebrow" for="fb-comment">FEEDBACK</label>
          <textarea
            id="fb-comment"
            name="comment"
            rows={5}
            class="pg-input promo__textarea"
            placeholder="YOUR THOUGHTS ON THE RELEASE..."
            required
          />
        </div>

        <div class="flex items-center gap-4">
          <button type="submit" class="btn btn--primary">
            TRANSMIT FEEDBACK
          </button>
          <span id="fb-status" class="text-micro text-fg-muted" aria-live="polite"></span>
        </div>
      </form>

      <!-- Success state -->
      <div id="promo-feedback-success" class="promo__success hidden">
        <span class="text-eyebrow text-accent">// TRANSMISSION COMPLETE</span>
        <p class="text-micro mt-3 text-fg-dim">FEEDBACK RECEIVED. PHANTOM GRID THANKS YOU.</p>
        <span class="pg-cursor mt-2"></span>
      </div>
    </div>

    <!-- Feedback list -->
    {feedbacks.length > 0 && (
      <div class="promo__section" id="promo-feedback-list">
        <p class="pg-section-title">// TRANSMISSIONS ({feedbacks.length})</p>
        <ol class="flex flex-col gap-4">
          {feedbacks.map((fb) => (
            <li class="promo__feedback-item">
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <span class="font-label font-bold uppercase text-fg text-[0.85rem] tracking-[0.12em]">{fb.name}</span>
                <span class="text-micro text-fg-muted flex-shrink-0">
                  {fb.created ? new Date(fb.created).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : ''}
                </span>
              </div>
              <p class="font-label text-fg-dim text-[0.8rem] leading-[1.7] tracking-[0.04em]">{fb.comment}</p>
            </li>
          ))}
        </ol>
      </div>
    )}

      </div>{/* end px-6 py-8 */}
    </div>{/* end promo__box */}
  </div>{/* end min-h-screen */}
</BaseLayout>

<style>
  .promo__box {
    background: var(--color-surface-low);
    border: 0.0625rem solid var(--color-border);
    box-shadow: 0 0 0 0.0625rem var(--color-accent-subtle);
    width: 100%;
  }

  .promo__box-header {
    background: var(--color-surface);
  }

  .promo__cover {
    box-shadow:
      0 0 0 0.0625rem var(--color-accent-subtle),
      0 0.5rem 2rem rgba(0, 0, 0, 0.5);
  }

  .promo__section {
    border: 0.0625rem solid var(--color-border);
    padding: 1.5rem;
    background: var(--color-surface);
  }

  /* AudioPlayer already has its own border — suppress when inside promo__section */
  .promo__section :global(.audio-player) {
    border: none;
    padding: 0;
    background: transparent;
  }

  .promo__tracklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    border: 0.0625rem solid var(--color-border);
    margin-top: 1rem;
  }

  .promo__track-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-bottom: 0.0625rem solid var(--color-border);
  }

  .promo__track-row:last-child {
    border-bottom: none;
  }

  .promo__textarea {
    resize: vertical;
    min-height: 7rem;
    line-height: 1.6;
  }

  .promo__success {
    padding: 1.5rem;
    border: 0.0625rem solid var(--color-accent-border);
    background: var(--color-accent-dim);
  }

  .promo__feedback-item {
    border-bottom: 0.0625rem solid var(--color-border);
    padding-bottom: 1rem;
  }

  .promo__feedback-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hidden {
    display: none;
  }

  /* Download spinner */
  [data-dl].dl--loading {
    pointer-events: none;
    opacity: 0.7;
    position: relative;
  }

  [data-dl].dl--loading::after {
    content: '';
    display: inline-block;
    width: 0.7em;
    height: 0.7em;
    border: 0.1em solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: dl-spin 0.7s linear infinite;
    margin-left: 0.5em;
    vertical-align: middle;
  }

  @keyframes dl-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  // ── Download spinner ────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLAnchorElement>('[data-dl]').forEach((link) => {
    link.addEventListener('click', () => {
      const original = link.innerHTML;
      link.classList.add('dl--loading');
      link.innerHTML = 'PREPARING&hellip;';
      // Reset after a few seconds (ZIP can take time, single track is fast)
      setTimeout(() => {
        link.classList.remove('dl--loading');
        link.innerHTML = original;
      }, 8000);
    });
  });

  // ── Feedback form ───────────────────────────────────────────────────────────
  const form     = document.getElementById('promo-feedback-form') as HTMLFormElement | null;
  const success  = document.getElementById('promo-feedback-success');
  const status   = document.getElementById('fb-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    status.textContent = 'TRANSMITTING...';

    const fd = new FormData(form);
    const body: Record<string, string> = {};
    fd.forEach((v, k) => { body[k] = String(v); });

    try {
      const res = await fetch('/api/promo/feedback', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Unknown error' }));
        status.textContent = `ERROR: ${(err as { error: string }).error}`;
        return;
      }

      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      status.textContent = 'CONNECTION FAILED. TRY AGAIN.';
    }
  });
</script>
