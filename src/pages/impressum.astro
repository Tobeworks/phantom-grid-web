---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="IMPRESSUM — PHANTOM GRID"
  description="Impressum für die Phantom Grid Website."
>
  <div class="max-w-7xl mx-auto px-8 py-8 pb-24 min-h-screen">

    <!-- Back nav -->
    <nav class="mb-12">
      <a href="/" class="text-eyebrow text-fg-dim no-underline transition-colors duration-200 hover:text-accent">
        ← PHANTOM GRID
      </a>
    </nav>

    <!-- Hero -->
    <section class="mb-16">
      <span class="text-eyebrow">LEGAL</span>
      <h1 class="font-label font-bold uppercase text-fg leading-[1.1] tracking-[0.25em] text-[clamp(2rem,5vw,3.5rem)] mt-4">
        Impressum
      </h1>
    </section>

    <!-- Content -->
    <section class="pg-surface p-8 md:p-12 max-w-4xl">
      <div class="legal-prose">
        <div class="mb-12">
          <div class="font-label font-bold text-label text-fg mb-2">Tobeworks — Tobias Lorsbach</div>
          <div class="space-y-4">
            <p>
              Neue Universitätsstraße 7<br />
              55116 Mainz
            </p>
            <p>
              Mobil: 0179/1259004<br />
              <span class="reverseaddr">ed.dirgenot@ollah</span>
            </p>
            <p>
              Geschäftsführung: Tobias Lorsbach<br />
              Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz: DE 021 843 01420
            </p>
          </div>
        </div>

        <div class="border-t border-border pt-8">
          <h3 class="mt-0 mb-4">Haftungshinweis</h3>
          <p>
            Trotz sorgfältiger inhaltlicher Kontrolle übernehmen wir keine Haftung für die Inhalte externer Links.
            Für den Inhalt der verlinkten Seiten sind ausschließlich deren Betreiber verantwortlich.
          </p>
          <p class="mt-4">
            <a href="https://tobeworks.de" target="_blank" rel="noopener noreferrer" class="text-accent no-underline transition-colors duration-200 hover:opacity-75">
              tobeworks.de ↗
            </a>
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .legal-prose h3 {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .legal-prose p {
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-fg-dim);
    line-height: 1.8;
  }

  .reverseaddr {
    unicode-bidi: bidi-override;
    direction: rtl;
  }
</style>
