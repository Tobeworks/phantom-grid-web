---
import BaseLayout from "../layouts/BaseLayout.astro";
import LedArray from "../components/LedArray.astro";
import ReleaseList from "../components/ReleaseList.astro";
import TerminalRain from "../components/TerminalRain.astro";
import pkg from "../../package.json";
---

<BaseLayout>

  <!-- ── Hero ── -->
  <div class="relative flex flex-col items-center justify-center min-h-screen p-8">
    <TerminalRain />

    <div class="relative z-[1] flex flex-col items-center">
      <div class="mb-16">
        <LedArray code="PG-001" />
      </div>

      <h1 class="home__wordmark">Phantom Grid</h1>

      <p class="home__tagline">Transmitting from Cyberspace_</p>

      <div class="flex gap-6 mb-12">
        <a
          class="home__icon-link"
          href="https://github.com/Tobeworks/phantom-grid-os"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z" clip-rule="evenodd"></path>
          </svg>
        </a>
        <a
          class="home__icon-link"
          href="https://phantomgrid.bandcamp.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Bandcamp">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
            <path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"></path>
          </svg>
        </a>
      </div>

      <div class="flex items-center gap-2 text-[0.75rem] tracking-[0.2em] text-fg-dim uppercase">
        SIGNAL INCOMING <span class="pg-cursor"></span>
      </div>
    </div>
  </div>

  <!-- ── Manifest ── -->
  <section class="border-y border-border bg-surface-low">
    <div class="max-w-7xl mx-auto px-8 py-20 flex flex-col gap-12">

      <header class="flex flex-col gap-4">
        <span class="text-eyebrow">// SIGNAL_ORIGIN</span>
        <h2 class="home__headline">
          Dark machines.<br />
          Raw signal.
        </h2>
      </header>

      <p class="font-label font-semibold uppercase text-fg-dim leading-[1.8] max-w-[38.75rem] text-[clamp(0.85rem,1.5vw,1rem)] tracking-[0.06em]">
        Phantom Grid is an independent electronic music label. No major. No
        algorithm. Just artists, machines, and the spaces between. Each release
        is a transmission — deliberate, limited, built to last.
      </p>

      <div class="grid grid-cols-[repeat(auto-fill,minmax(13.75rem,1fr))] border border-border">
        {[
          { n: '01', title: 'THE SOUND',    body: 'Electronic music rooted in texture and tension. Industrial pulse, ambient drift, synthetic rhythm — built for headphones and club systems alike.' },
          { n: '02', title: 'INDEPENDENT',  body: 'No label politics. No release windows. Artists ship when the work is ready — direct from the studio to the listener.' },
          { n: '03', title: 'ON WAX & WIRE', body: 'High-quality audio, buy and stream on Bandcamp. Selected releases on vinyl soon.' },
          { n: '04', title: 'TRANSPARENT',  body: 'The label runs on an open OS Repo — brand, data, and workflow visible to anyone. Signal over hype.' },
          { n: '05', title: 'NO ALGORITHM', body: 'Built for listeners and DJs, not feeds. No playlist chasing, no engagement farming. If it reaches you, it\'s because it was meant to.' },
        ].map(({ n, title, body }) => (
          <div class="manifest__node flex flex-col gap-2 p-6 border-r border-b border-border relative">
            <span class="text-micro text-accent">{n}</span>
            <h3 class="font-label font-bold uppercase text-fg text-[0.9rem] tracking-[0.18em]">{title}</h3>
            <p class="font-label font-semibold uppercase text-fg-dim text-[0.75rem] tracking-[0.06em] leading-[1.7]">{body}</p>
          </div>
        ))}
      </div>

      <div class="flex items-center gap-6">
        <span class="pg-divider"></span>
        <span class="text-micro whitespace-nowrap shrink-0">EST. 2026 — TRANSMITTING FROM CYBERSPACE</span>
        <span class="pg-divider"></span>
      </div>

    </div>
  </section>

  <!-- ── Releases ── -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-8">
      <ReleaseList />
    </div>
  </section>

  <footer class="text-center py-12 px-4 text-[0.65rem] tracking-[0.2em] text-fg-muted uppercase border-t border-border">
    EST. 2026 — CYBERSPACE —
    <a href="https://phantomgrid.bandcamp.com/" target="_blank" rel="noopener noreferrer"
       class="text-fg-faint no-underline transition-colors duration-200 hover:text-accent">
      BANDCAMP
    </a>
    — v{pkg.version}
  </footer>

</BaseLayout>

<style>
  /* Scoped CSS — only for animations and pseudo-elements that Tailwind can't handle */

  /* ── Wordmark: VHS flicker animation ── */
  .home__wordmark {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-family: var(--font-label);
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-fg);
    text-transform: uppercase;
    margin-bottom: 1rem;
    line-height: 1;
    animation: vhs-flicker 6s step-end infinite;
  }

  @keyframes vhs-flicker {
    0%, 88%, 91%, 96% {
      text-shadow:
        0.125rem 0 var(--color-accent-glow),
        -0.125rem 0 var(--color-cyan-dim),
        0 0 1.25rem var(--color-fg-muted),
        0 0 3.75rem rgba(220, 220, 220, 0.04);
      opacity: 1;
      transform: none;
    }
    89% {
      text-shadow: 0.3125rem 0 var(--color-accent), -0.3125rem 0 var(--color-cyan);
      opacity: 0.75;
      transform: translateX(0.25rem);
    }
    90% {
      text-shadow: -0.25rem 0 var(--color-accent-strong), 0.25rem 0 var(--color-cyan-dim);
      opacity: 0.85;
      transform: translateX(-0.1875rem);
    }
    97% { opacity: 0.6; transform: translateX(0.125rem); }
    97.5%, 100% { opacity: 1; transform: none; }
  }

  /* ── Tagline: clamp size + text-shadow ── */
  .home__tagline {
    font-size: clamp(0.8rem, 2vw, 1rem);
    font-family: var(--font-label);
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    text-transform: uppercase;
    text-shadow: 0 0 0.625rem var(--color-accent-glow);
    margin-bottom: 2rem;
  }

  /* ── Icon links: filter drop-shadow on hover ── */
  .home__icon-link {
    display: flex;
    color: var(--color-fg-faint);
    text-decoration: none;
    transition: color 0.2s, filter 0.2s;
  }
  .home__icon-link:hover {
    color: var(--color-fg);
    filter: drop-shadow(0 0 0.5rem var(--color-fg-dim));
  }

  /* ── Headline: clamp size ── */
  .home__headline {
    font-family: var(--font-label);
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg);
    line-height: 1.2;
    max-width: 43.75rem;
  }

  /* ── Manifest node: ::before hover accent line ── */
  .manifest__node::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 0.125rem;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .manifest__node:hover::before {
    opacity: 1;
  }
</style>
