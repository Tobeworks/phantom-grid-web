---
import BaseLayout from "../layouts/BaseLayout.astro";
import LedArray from "../components/LedArray.astro";
import pkg from "../../package.json";
import { Github } from "lucide-astro";
---

<BaseLayout>
  <div class="hero">
    <LedArray />

    <h1 class="wordmark">Phantom Grid</h1>
    <p class="tagline">Transmitting from Cyberspace_</p>

    <a
      class="github-link"
      href="https://github.com/Tobeworks/phantom-grid-os"
      target="_blank">
      <svg
        class="w-6 h-6 text-gray-800 dark:text-white"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="36"
        height="36"
        fill="currentColor"
        viewBox="0 0 24 24">
        <path
          fill-rule="evenodd"
          d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z"
          clip-rule="evenodd"></path>
      </svg>
    </a>

    <div class="status">
      SIGNAL INCOMING <span class="cursor"></span>
    </div>
  </div>

  <footer class="footer">
    EST. 2026 — CYBERSPACE — v{pkg.version}
  </footer>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 0;
    padding: 2rem;
  }

  .wordmark {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-fg);
    text-transform: uppercase;
    margin-bottom: 1rem;
    line-height: 1;
    animation: vhs-flicker 6s step-end infinite;
  }

  @keyframes vhs-flicker {
    0%,
    100% {
      text-shadow:
        2px 0 rgba(214, 82, 76, 0.6),
        -2px 0 rgba(0, 200, 255, 0.25),
        0 0 20px rgba(220, 220, 220, 0.12),
        0 0 60px rgba(220, 220, 220, 0.04);
      opacity: 1;
      transform: none;
    }
    88% {
      text-shadow:
        2px 0 rgba(214, 82, 76, 0.6),
        -2px 0 rgba(0, 200, 255, 0.25),
        0 0 20px rgba(220, 220, 220, 0.12),
        0 0 60px rgba(220, 220, 220, 0.04);
      opacity: 1;
      transform: none;
    }
    89% {
      text-shadow:
        5px 0 rgba(214, 82, 76, 0.9),
        -5px 0 rgba(0, 200, 255, 0.5);
      opacity: 0.75;
      transform: translateX(4px);
    }
    90% {
      text-shadow:
        -4px 0 rgba(214, 82, 76, 0.8),
        4px 0 rgba(0, 200, 255, 0.4);
      opacity: 0.85;
      transform: translateX(-3px);
    }
    91% {
      text-shadow:
        2px 0 rgba(214, 82, 76, 0.6),
        -2px 0 rgba(0, 200, 255, 0.25);
      opacity: 1;
      transform: none;
    }
    96% {
      text-shadow:
        2px 0 rgba(214, 82, 76, 0.6),
        -2px 0 rgba(0, 200, 255, 0.25);
      opacity: 1;
      transform: none;
    }
    97% {
      opacity: 0.6;
      transform: translateX(2px);
    }
    97.5% {
      opacity: 1;
      transform: none;
    }
  }

  .tagline {
    font-size: clamp(0.8rem, 2vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(214, 82, 76, 0.5);
    margin-bottom: 2rem;
  }

  .github-link {
    display: flex;
    color: rgba(220, 220, 220, 0.3);
    text-decoration: none;
    margin-bottom: 3rem;
    transition:
      color 0.2s,
      filter 0.2s;
  }

  .github-link:hover {
    color: var(--color-fg);
    filter: drop-shadow(0 0 8px rgba(220, 220, 220, 0.4));
  }

  .status {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(220, 220, 220, 0.4);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 14px;
    background: var(--color-accent);
    box-shadow: 0 0 10px rgba(214, 82, 76, 0.7);
    animation: blink 1.2s step-end infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .footer {
    position: fixed;
    bottom: 2rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: rgba(220, 220, 220, 0.2);
    text-transform: uppercase;
  }

  .footer a {
    color: rgba(214, 82, 76, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer a:hover {
    color: var(--color-accent);
  }
</style>
