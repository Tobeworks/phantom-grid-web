---
interface Track {
  number: number;
  title: string;
  url: string;
}

interface Props {
  tracks: Track[];
}

const { tracks } = Astro.props;
const uid = `player-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="audio-player" id={uid} data-tracks={JSON.stringify(tracks)}>

  <!-- Now playing bar -->
  <div class="audio-player__now-playing">
    <span class="audio-player__eyebrow text-eyebrow">// NOW_PLAYING</span>
    <span class="audio-player__track-info">
      <span class="audio-player__track-title">—</span>
      <span class="audio-player__track-index text-micro">— / {tracks.length}</span>
    </span>
  </div>

  <!-- Waveform + controls row -->
  <div class="audio-player__main">
    <!-- Animated waveform -->
    <div class="audio-player__waveform" aria-hidden="true">
      {Array.from({ length: 10 }, (_, i) => (
        <div class="audio-player__bar" style={`animation-delay: ${i * 80}ms`} />
      ))}
    </div>

    <!-- Transport controls -->
    <div class="audio-player__controls">
      <button class="audio-player__btn audio-player__btn--prev" aria-label="Previous track">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
          <rect x="0" y="1" width="2" height="12"/>
          <polygon points="12,1 2,7 12,13"/>
        </svg>
      </button>
      <button class="audio-player__btn audio-player__btn--play" aria-label="Play">
        <!-- play icon (default) -->
        <svg class="audio-player__icon-play" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
          <polygon points="3,1 13,8 3,15"/>
        </svg>
        <!-- pause icon (shown when playing) -->
        <svg class="audio-player__icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
          <rect x="2" y="1" width="4" height="14"/>
          <rect x="10" y="1" width="4" height="14"/>
        </svg>
      </button>
      <button class="audio-player__btn audio-player__btn--next" aria-label="Next track">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
          <rect x="12" y="1" width="2" height="12"/>
          <polygon points="2,1 12,7 2,13"/>
        </svg>
      </button>
    </div>

    <!-- Time display -->
    <div class="audio-player__time text-micro">
      <span class="audio-player__time-current">0:00</span>
      <span class="audio-player__time-sep">/</span>
      <span class="audio-player__time-total">0:00</span>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="audio-player__progress-track" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0">
    <div class="audio-player__progress-fill"></div>
    <div class="audio-player__progress-head"></div>
  </div>

  <!-- Track list -->
  <ol class="audio-player__tracklist">
    {tracks.map((track) => {
      const label = track.title.replace(/^.*?\s{2,}/, '').trim() || track.title;
      return (
        <li class="audio-player__track" data-index={track.number - 1}>
          <span class="audio-player__track-num">{String(track.number).padStart(2, '0')}</span>
          <span class="audio-player__track-label">{label}</span>
          <svg class="audio-player__track-playing-icon" width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
            <polygon points="1,1 9,5 1,9"/>
          </svg>
        </li>
      );
    })}
  </ol>

</div>

<style>
  /* ── Block ── */
  .audio-player {
    background: var(--color-surface-low);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    user-select: none;
  }

  /* ── Now playing ── */
  .audio-player__now-playing {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .audio-player__eyebrow {
    color: var(--color-accent);
  }

  .audio-player__track-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .audio-player__track-title {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .audio-player__track-index {
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Main row ── */
  .audio-player__main {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  /* ── Waveform ── */
  .audio-player__waveform {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 28px;
    flex-shrink: 0;
  }

  .audio-player__bar {
    width: 3px;
    background: var(--color-accent);
    border-radius: 1px;
    animation: pg-wave 600ms ease-in-out infinite alternate;
    animation-play-state: paused;
    height: 4px;
    box-shadow: 0 0 4px rgba(214, 82, 76, 0.4);
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .audio-player--playing .audio-player__bar {
    animation-play-state: running;
    opacity: 1;
  }

  .audio-player__bar:nth-child(1)  { --h: 8px;  }
  .audio-player__bar:nth-child(2)  { --h: 18px; }
  .audio-player__bar:nth-child(3)  { --h: 24px; }
  .audio-player__bar:nth-child(4)  { --h: 14px; }
  .audio-player__bar:nth-child(5)  { --h: 28px; }
  .audio-player__bar:nth-child(6)  { --h: 20px; }
  .audio-player__bar:nth-child(7)  { --h: 10px; }
  .audio-player__bar:nth-child(8)  { --h: 22px; }
  .audio-player__bar:nth-child(9)  { --h: 16px; }
  .audio-player__bar:nth-child(10) { --h: 6px;  }

  @keyframes pg-wave {
    from { height: 4px; }
    to   { height: var(--h, 16px); }
  }

  /* ── Controls ── */
  .audio-player__controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .audio-player__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-fg-dim);
    cursor: pointer;
    padding: 0.4rem;
    transition: color 0.15s, border-color 0.15s, box-shadow 0.15s;
    width: 32px;
    height: 32px;
  }

  .audio-player__btn:hover {
    color: var(--color-fg);
    border-color: rgba(214, 82, 76, 0.4);
  }

  .audio-player__btn--play {
    width: 40px;
    height: 40px;
    border-color: rgba(214, 82, 76, 0.3);
    color: var(--color-accent);
  }

  .audio-player__btn--play:hover {
    box-shadow: 0 0 12px rgba(214, 82, 76, 0.3);
    border-color: var(--color-accent);
  }

  /* pause icon hidden by default, shown when playing */
  .audio-player__icon-pause { display: none; }
  .audio-player--playing .audio-player__icon-play  { display: none; }
  .audio-player--playing .audio-player__icon-pause { display: block; }

  /* ── Time ── */
  .audio-player__time {
    margin-left: auto;
    display: flex;
    gap: 0.3rem;
    align-items: center;
    flex-shrink: 0;
  }

  .audio-player__time-sep {
    color: var(--color-fg-muted);
    font-size: 0.6rem;
  }

  /* ── Progress bar ── */
  .audio-player__progress-track {
    position: relative;
    height: 4px;
    background: var(--color-surface-high);
    cursor: pointer;
    outline: none;
  }

  .audio-player__progress-track:focus-visible {
    box-shadow: 0 0 0 2px rgba(214, 82, 76, 0.4);
  }

  .audio-player__progress-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0%;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(214, 82, 76, 0.5);
    transition: width 0.1s linear;
    pointer-events: none;
  }

  .audio-player__progress-head {
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(214, 82, 76, 0.7);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, left 0.1s linear;
  }

  .audio-player__progress-track:hover .audio-player__progress-head {
    opacity: 1;
  }

  /* ── Track list ── */
  .audio-player__tracklist {
    list-style: none;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .audio-player__track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.5rem;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: background 0.15s;
  }

  .audio-player__track:hover {
    background: var(--color-surface);
  }

  .audio-player__track--active {
    background: var(--color-surface);
    border-bottom-color: rgba(214, 82, 76, 0.15);
  }

  .audio-player__track-num {
    font-family: var(--font-label);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    width: 1.5rem;
    flex-shrink: 0;
    font-weight: 600;
  }

  .audio-player__track--active .audio-player__track-num {
    color: var(--color-accent);
  }

  .audio-player__track-label {
    font-family: var(--font-label);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .audio-player__track--active .audio-player__track-label {
    color: var(--color-fg);
  }

  .audio-player__track-playing-icon {
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .audio-player--playing .audio-player__track--active .audio-player__track-playing-icon {
    opacity: 1;
  }
</style>

<script>
  function initPlayer(root: HTMLElement) {
    const tracksRaw = root.dataset.tracks;
    if (!tracksRaw) return;
    const tracks: { number: number; title: string; url: string }[] = JSON.parse(tracksRaw);

    const audio = new Audio();
    let currentIndex = 0;
    let isPlaying = false;

    // Elements
    const trackTitle  = root.querySelector<HTMLElement>('.audio-player__track-title')!;
    const trackIndex  = root.querySelector<HTMLElement>('.audio-player__track-index')!;
    const btnPlay     = root.querySelector<HTMLButtonElement>('.audio-player__btn--play')!;
    const btnPrev     = root.querySelector<HTMLButtonElement>('.audio-player__btn--prev')!;
    const btnNext     = root.querySelector<HTMLButtonElement>('.audio-player__btn--next')!;
    const timeCurrent = root.querySelector<HTMLElement>('.audio-player__time-current')!;
    const timeTotal   = root.querySelector<HTMLElement>('.audio-player__time-total')!;
    const progressTrack = root.querySelector<HTMLElement>('.audio-player__progress-track')!;
    const progressFill  = root.querySelector<HTMLElement>('.audio-player__progress-fill')!;
    const progressHead  = root.querySelector<HTMLElement>('.audio-player__progress-head')!;
    const trackItems  = root.querySelectorAll<HTMLElement>('.audio-player__track');

    function fmt(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function loadTrack(idx: number, autoPlay = false) {
      const t = tracks[idx];
      if (!t) return;
      currentIndex = idx;
      audio.src = t.url;
      audio.load();

      // strip "Artist   " prefix (2+ spaces)
      const label = t.title.replace(/^.*?\s{2,}/, '').trim() || t.title;
      trackTitle.textContent = label;
      trackIndex.textContent = `${idx + 1} / ${tracks.length}`;
      timeCurrent.textContent = '0:00';
      timeTotal.textContent   = '0:00';
      progressFill.style.width = '0%';
      progressHead.style.left  = '0%';

      trackItems.forEach((el, i) => {
        el.classList.toggle('audio-player__track--active', i === idx);
      });

      if (autoPlay) {
        audio.play().then(() => setPlaying(true)).catch(() => {});
      }
    }

    function setPlaying(state: boolean) {
      isPlaying = state;
      root.classList.toggle('audio-player--playing', state);
      btnPlay.setAttribute('aria-label', state ? 'Pause' : 'Play');
    }

    btnPlay.addEventListener('click', () => {
      if (audio.src === '' || audio.src === window.location.href) {
        loadTrack(0, true);
        return;
      }
      if (isPlaying) {
        audio.pause();
        setPlaying(false);
      } else {
        audio.play().then(() => setPlaying(true)).catch(() => {});
      }
    });

    btnPrev.addEventListener('click', () => {
      const idx = (currentIndex - 1 + tracks.length) % tracks.length;
      loadTrack(idx, isPlaying);
    });

    btnNext.addEventListener('click', () => {
      const idx = (currentIndex + 1) % tracks.length;
      loadTrack(idx, isPlaying);
    });

    // Click on track item
    trackItems.forEach((el, i) => {
      el.addEventListener('click', () => loadTrack(i, true));
    });

    // Audio events
    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      timeCurrent.textContent = fmt(audio.currentTime);
      progressFill.style.width = `${pct}%`;
      progressHead.style.left  = `${pct}%`;
      progressTrack.setAttribute('aria-valuenow', String(Math.round(pct)));
    });

    audio.addEventListener('loadedmetadata', () => {
      timeTotal.textContent = fmt(audio.duration);
    });

    audio.addEventListener('ended', () => {
      const next = currentIndex + 1;
      if (next < tracks.length) {
        loadTrack(next, true);
      } else {
        setPlaying(false);
        progressFill.style.width = '0%';
        progressHead.style.left  = '0%';
        timeCurrent.textContent  = '0:00';
      }
    });

    audio.addEventListener('pause', () => setPlaying(false));
    audio.addEventListener('play',  () => setPlaying(true));

    // Seek on progress click
    progressTrack.addEventListener('click', (e) => {
      if (!audio.duration) return;
      const rect = progressTrack.getBoundingClientRect();
      const pct  = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });

    // Keyboard seek on progress bar
    progressTrack.addEventListener('keydown', (e) => {
      if (!audio.duration) return;
      if (e.key === 'ArrowRight') audio.currentTime = Math.min(audio.currentTime + 5, audio.duration);
      if (e.key === 'ArrowLeft')  audio.currentTime = Math.max(audio.currentTime - 5, 0);
    });

    // Load first track (no autoplay)
    loadTrack(0, false);
  }

  // Init all players on the page
  document.querySelectorAll<HTMLElement>('.audio-player').forEach(initPlayer);
</script>
