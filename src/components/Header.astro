---
import { Menu, X, Github, ExternalLink } from 'lucide-astro';

const navLinks = [
  { label: 'Releases', href: '/#releases' },
  { label: 'Newsletter', href: '/newsletter' },
];

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/Tobeworks/phantom-grid-os', icon: Github },
  { label: 'Bandcamp', href: 'https://phantomgrid.bandcamp.com/', icon: ExternalLink },
];
---

<header id="pg-header" class="fixed top-0 left-0 right-0 z-100 flex items-center justify-between px-6 lg:px-10 h-16 bg-bg/90 backdrop-blur-md border-b border-transparent transition-[background,border-color] duration-300">
  <a href="/" class="font-label font-bold text-[0.75rem] tracking-[0.22em] uppercase text-fg no-underline hover:text-accent transition-colors duration-200">
    Phantom Grid
  </a>

  <!-- Desktop nav -->
  <nav class="hidden sm:flex items-center gap-8">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class="font-label text-[0.7rem] tracking-[0.25em] uppercase text-fg-dim no-underline transition-colors duration-200 hover:text-fg">
        {label}
      </a>
    ))}
    <div class="w-px h-4 bg-border"></div>
    {socialLinks.map(({ label, href, icon: Icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-fg-muted transition-colors duration-200 hover:text-fg"
        aria-label={label}>
        <Icon size={16} />
      </a>
    ))}
  </nav>

  <!-- Mobile hamburger -->
  <button
    type="button"
    class="sm:hidden text-fg p-2 transition-colors duration-200 hover:text-accent"
    aria-label="Open menu"
    data-pg-menu-toggle>
    <Menu size={20} />
  </button>
</header>

<!-- Mobile overlay -->
<div id="pg-mobile-menu" class="fixed inset-0 z-200 pointer-events-none opacity-0 transition-opacity duration-300">
  <div class="absolute inset-0 bg-bg/95 backdrop-blur-lg" data-pg-menu-backdrop></div>
  <div class="relative h-full flex flex-col items-center justify-center px-8">
    <button
      type="button"
      class="absolute top-5 right-6 text-fg p-2 transition-colors duration-200 hover:text-accent"
      aria-label="Close menu"
      data-pg-menu-toggle>
      <X size={24} />
    </button>
    <nav class="text-center space-y-1">
      {navLinks.map(({ label, href }, i) => (
        <a
          href={href}
          class="mobile-nav-item block py-3 font-label font-bold uppercase text-2xl tracking-widest text-fg-dim no-underline transition-colors duration-200 hover:text-accent"
          style={`animation-delay: ${100 + i * 50}ms`}
          data-pg-menu-close>
          {label}
        </a>
      ))}
    </nav>
    <div class="flex gap-6 mt-12">
      {socialLinks.map(({ label, href, icon: Icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-fg-muted transition-colors duration-200 hover:text-accent"
          aria-label={label}>
          <Icon size={20} />
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const toggleButtons = document.querySelectorAll('[data-pg-menu-toggle]');
  const menu = document.getElementById('pg-mobile-menu');
  const closeLinks = document.querySelectorAll('[data-pg-menu-close]');
  const backdrop = document.querySelector('[data-pg-menu-backdrop]');

  function openMenu() {
    menu?.classList.remove('pointer-events-none', 'opacity-0');
    menu?.classList.add('pointer-events-auto', 'opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('pointer-events-none', 'opacity-0');
    menu?.classList.remove('pointer-events-auto', 'opacity-100');
    document.body.style.overflow = '';
  }

  toggleButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (menu?.classList.contains('opacity-100')) {
        closeMenu();
      } else {
        openMenu();
      }
    });
  });

  closeLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>

<style>
  @keyframes mobile-nav-enter {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .mobile-nav-item {
    animation: mobile-nav-enter 0.35s ease-out both;
  }
</style>
