---
interface Props {
  lines?: string[];
  prompt?: string;
  title?: string;
}

const {
  lines = [],
  prompt = 'PHANTOM_GRID:~$',
  title = 'TERMINAL',
} = Astro.props;
---

<div class="terminal">
  <div class="terminal__header flex items-center gap-3 px-4 py-2">
    <div class="terminal__dots flex gap-1.5">
      <span class="terminal__dot terminal__dot--active"></span>
      <span class="terminal__dot"></span>
      <span class="terminal__dot"></span>
    </div>
    <span class="terminal__title flex-1 text-center uppercase">{title}</span>
  </div>
  <div class="terminal__body flex flex-col min-h-52">
    {lines.map((line) => (
      <div class="terminal__line flex items-baseline gap-2">
        {line.startsWith('>') ? (
          <span class="terminal__output">{line.slice(1).trim()}</span>
        ) : (
          <>
            <span class="terminal__prompt">{prompt}</span>
            <span class="terminal__cmd">{line}</span>
          </>
        )}
      </div>
    ))}
    <div class="terminal__line flex items-baseline gap-2">
      <span class="terminal__prompt">{prompt}</span>
      <span class="terminal__cursor"></span>
    </div>
  </div>
</div>

<style>
  .terminal {
    background: var(--color-bg);
    border: 1px solid rgba(214, 82, 76, 0.25);
    box-shadow:
      0 0 30px rgba(214, 82, 76, 0.08),
      inset 0 0 60px rgba(0, 0, 0, 0.4);
    font-family: 'Courier New', 'Monaco', monospace;
    font-size: 0.8rem;
    overflow: hidden;
  }

  .terminal__header {
    background: var(--color-surface-low);
    border-bottom: 1px solid rgba(214, 82, 76, 0.15);
  }

  .terminal__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(214, 82, 76, 0.3);
    box-shadow: 0 0 6px rgba(214, 82, 76, 0.3);
  }

  .terminal__dot--active {
    background: rgba(214, 82, 76, 0.7);
    box-shadow: 0 0 8px rgba(214, 82, 76, 0.6);
  }

  .terminal__title {
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--color-fg-dim);
  }

  .terminal__body {
    padding: 1.25rem 1.5rem;
    gap: 0.35rem;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
  }

  .terminal__line {
    line-height: 1.6;
  }

  .terminal__prompt {
    color: var(--color-accent);
    text-shadow: 0 0 8px rgba(214, 82, 76, 0.6);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .terminal__cmd {
    color: var(--color-fg);
    text-shadow: 0 0 6px rgba(220, 220, 220, 0.15);
  }

  .terminal__output {
    color: var(--color-fg-dim);
    padding-left: 0.25rem;
    font-style: italic;
  }

  .terminal__cursor {
    display: inline-block;
    width: 8px;
    height: 1rem;
    background: var(--color-accent);
    box-shadow: 0 0 10px rgba(214, 82, 76, 0.8);
    animation: blink 1.2s step-end infinite;
    vertical-align: middle;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
